	quest.3CA6E03A937B5C2F.title: "Platinum Seeds"
	quest.3E58E0FB809F3BD9.quest_desc: [
		"Nether Star Seeds are an endgame crop for turning Wither power into a slow but renewable essence line."
		" "
		"Nine Nether Star Essence craft one Quarter Star, and four Quarter Stars can be assembled into a Nether Star."
	]
