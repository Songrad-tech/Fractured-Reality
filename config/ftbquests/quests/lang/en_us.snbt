	quest.028183CAF76216EB.title: "Craft a Copper Casing"
	quest.02FE952A15865F26.title: "Wooden Construction Stick"
	quest.0329DD5F78FB3E0C.quest_desc: [
		"§6A Blaze Burner is the heat source behind stronger mixing recipes.§r"
		" "
		"§fCraft an Empty Blaze Burner, then right-click a Blaze Spawner with it to capture the flame.§r"
		" "
		"§cBlaze Spawners are usually found in Nether Fortresses.§r"
	]
	quest.0329DD5F78FB3E0C.quest_subtitle: "Controlled Heat"
	quest.0329DD5F78FB3E0C.title: "Capture a Blaze Burner"
	quest.033F07AD47AC2AB2.title: "Linking Tool"
	quest.03A760BECFFD5126.quest_desc: [
		"The catacombs still have a guardian, and it has not forgotten its duty."
