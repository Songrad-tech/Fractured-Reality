	quest.449B86794FC6FCE9.quest_subtitle: "Cultivated Fish Essence"
	quest.449B86794FC6FCE9.title: "Fish Seeds"
	quest.44BAE70AE87741B8.quest_desc: [
		"§6Brass Casings give advanced Create machines the frame they need.§r"
		" "
		"§fUse Brass on stripped logs, just like the earlier casing recipes.§r"
		" "
		"§7This is where your factory starts becoming less improvised.§r"
	]
	quest.44BAE70AE87741B8.quest_subtitle: "Advanced Framing"
	quest.44BAE70AE87741B8.title: "Craft a Brass Casing"
	quest.45739EFF174B971C.quest_desc: ["Slime Seeds make sticky crafting materials renewable without hunting swamps or caves."]
	quest.45739EFF174B971C.quest_subtitle: "Cultivated Slime Essence"
	quest.45739EFF174B971C.title: "Slime Seeds"
	quest.459A613EBCC07CF4.quest_desc: [
		"§6The Copper Core marks the heated middle of the Mechanical Age.§r"
		" "
		"§fWith it, fluid handling, heat, and stronger processing become reliable tools instead of experiments.§r"
	]
	quest.459A613EBCC07CF4.quest_subtitle: "Heated Machinery"
	quest.459A613EBCC07CF4.title: "Craft a Copper Core"
	quest.467A80382231A9C6.quest_desc: [
		"§fWelcome, traveler.§r"
		" "
		"§7You may have already noticed the cracks spreading across the sky. This world is no longer the one you once knew.§r"
		" "
		"§8Something shattered reality itself. Strange energies now flow through the land, twisting nature, machines, and even dimensions beyond comprehension.§r"
		" "
		"§7As you explore, you will uncover forgotten technologies, corrupted ecosystems, and secrets buried deep within fractured worlds.§r"
		" "
		"§8But for now...§r"
		" "
		"§fStart simple.§r"
		"§6Gather wood.§r"
		"§6Survive.§r"
	]
	quest.467A80382231A9C6.title: "Welcome to Fractured Reality"
	quest.46D41410B1D4C616.quest_desc: ["Forgotten Seeds preserve ancient Undergarden power in a renewable form."]
	quest.46D41410B1D4C616.quest_subtitle: "Cultivated Forgotten Essence"
	quest.46D41410B1D4C616.title: "Forgotten Seeds"
	quest.46F32CC3B5E43788.quest_desc: [
		"&7The ME Controller is the heart of a growing network, distributing power and channels through its faces.&r"
		" "
		"&eEach controller face supplies channels; Smart Cables reveal how many are in use.&r"
	]
	quest.46F32CC3B5E43788.quest_subtitle: "Digital Progression"
	quest.46F32CC3B5E43788.title: "Build an ME Controller"
	quest.46FDFD2428B06D4C.quest_desc: ["Steel Seeds strengthen your infrastructure with renewable heavy metal essence."]
	quest.46FDFD2428B06D4C.quest_subtitle: "Cultivated Steel Essence"
	quest.46FDFD2428B06D4C.title: "Steel Seeds"
	quest.47240678096167BB.quest_desc: ["Adamant Seeds cultivate stubborn, high-tier essence for the strongest material gates."]
	quest.47240678096167BB.quest_subtitle: "Cultivated Adamant Essence"
	quest.47240678096167BB.title: "Adamant Seeds"
	quest.473E6DE55188B7D4.quest_desc: ["&7The Logic Press creates printed circuits for common network devices.&r"]
	quest.473E6DE55188B7D4.quest_subtitle: "Printed Circuit Pattern"
	quest.473E6DE55188B7D4.title: "Find the Logic Press"
	quest.4787C1D384778BEA.title: "Golden Glider"
	quest.47901AF510FE12FC.quest_desc: ["Armadillo Seeds preserve scute-related resources in a compact magical crop."]
	quest.47901AF510FE12FC.quest_subtitle: "Cultivated Armadillo Essence"
	quest.47901AF510FE12FC.title: "Armadillo Seeds"
	quest.47BE189106F666DD.quest_desc: [
		"§6Challenge: Gold is expensive in machines, logistics, and powered crafting.§r"
		" "
		"§fProduce or gather 256 Gold Ingots through your automated resource setup.§r"
		" "
		"§7If this takes a while, that is fine: the point is to let the system work for you.§r"
	]
	quest.47BE189106F666DD.quest_subtitle: "Automation Check"
	quest.47BE189106F666DD.title: "Generate Gold"
	quest.47F92CA7E0294DDA.quest_desc: [
		"Begin with the desires centered on caring for bees and their home."
		" "
		"Breed bees, build hives, drink honey, and feed the colony. Check the Bumblezone advancement tab for exact counters."
	]
	quest.47F92CA7E0294DDA.quest_subtitle: "Care for the Colony"
	quest.47F92CA7E0294DDA.title: "The Queen's Beekeeping"
	quest.48100508EA4A0312.quest_desc: [
		"&7The Drone Port introduces autonomous transport between configured locations.&r"
		" "
		"&eStart with nearby endpoints so range, access, and filters are easy to verify.&r"
	]
	quest.48100508EA4A0312.quest_subtitle: "Powered Industry"
	quest.48100508EA4A0312.title: "Build a Drone Port"
	quest.48149D3CD7A9E97C.title: "Fractured Tools"
	quest.48AAD65FFE4AE1FF.quest_desc: ["Honey Seeds bottle the sweetness of bees into a calmer, crop-based resource path."]
	quest.48AAD65FFE4AE1FF.quest_subtitle: "Cultivated Honey Essence"
	quest.48AAD65FFE4AE1FF.title: "Honey Seeds"
	quest.48DA5F1CC92B5184.quest_desc: [
		"§7Technology progression is intentionally gated.§r"
		" "
		"§fYou are expected to advance through different technological eras in a specific order.§r"
		" "
		"§7Each age unlocks new possibilities, dimensions, and systems.§r"
		" "
		"§6Follow the main Progression chapters to guide your journey.§r"
	]
	quest.48DA5F1CC92B5184.title: "Progression Matters"
	quest.491415E3200FC513.quest_desc: [
		"&7The Large Solar Panel produces passive power whenever it can see the sky.&r"
		" "
		"&eNight and poor sky access stop production, so keep backup energy storage.&r"
	]
	quest.491415E3200FC513.quest_subtitle: "Electrical Generation"
	quest.491415E3200FC513.title: "Build a Large Solar Panel"
	quest.494AE9D1D5FEA6A5.quest_desc: ["Coal Seeds keep early fuel and carbon recipes moving even when mining slows down."]
