	quest.3A60A19D449B06E5.title: "Blaze Seeds"
	quest.3A7A7F0160A7E9A4.quest_desc: [
		"§6Challenge: Zinc is one of Create's most important metals, so automating it pays off quickly.§r"
		" "
		"§fProduce or gather 256 Zinc Ingots to validate the Asurine generation line.§r"
		" "
		"§7Once this runs on its own, Andesite Alloy and Brass become much easier to sustain.§r"
	]
