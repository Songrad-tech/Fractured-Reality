	quest.339B1B43D36D8DB4.quest_desc: [
		"Enter The Bumblezone and begin exploring its enormous honeycomb caverns."
		" "
		"Most creatures are peaceful until the hive considers you a threat."
	]
	quest.339B1B43D36D8DB4.quest_subtitle: "Beyond the Honey"
