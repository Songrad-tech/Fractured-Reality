	quest.45739EFF174B971C.title: "Slime Seeds"
	quest.459A613EBCC07CF4.quest_desc: [
		"§6The Copper Core marks the heated middle of the Mechanical Age.§r"
		" "
		"§fWith it, fluid handling, heat, and stronger processing become reliable tools instead of experiments.§r"
	]
