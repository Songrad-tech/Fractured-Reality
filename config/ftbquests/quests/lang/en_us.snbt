	quest.3E58E0FB809F3BD9.title: "Nether Star Seeds"
	quest.3E7246FF565DE837.quest_desc: [
		"§7The Spout fills items with fluids, unlocking compact fluid crafting lines and many custom recipes.§r"
		" "
		"§fConnect a pipe or tank above it, then pass items underneath on a Depot or Belt.§r"
	]
	quest.3E7246FF565DE837.quest_subtitle: "Fluid Application"
	quest.3E7246FF565DE837.title: "Craft a Spout"
	quest.3EC6888629E95574.quest_desc: ["Redstone Seeds keep circuits, machines, and automation logic supplied from the field."]
	quest.3EC6888629E95574.quest_subtitle: "Cultivated Redstone Essence"
	quest.3EC6888629E95574.title: "Redstone Seeds"
	quest.3EFEC4006AB93CCC.quest_desc: [
		"§7Veridium is another Create stone resource found through exploration and mining.§r"
		" "
		"§fGather 16 Veridium to prepare the custom core linked to Copper generation.§r"
		" "
		"§eExplore caves and stone layers first; the automation reward comes after this setup step.§r"
