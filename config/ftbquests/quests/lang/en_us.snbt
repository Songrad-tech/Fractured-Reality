	quest.248863E10972CDFC.title: "End Seeds"
	quest.25A8683648E2B093.quest_desc: [
		"§7The Deployer repeats right-click actions for you.§r"
		" "
		"§fGive it rotation, place an item in its filter or hand, and let it click for you.§r"
		" "
		"§6It is quietly one of the most useful early machines.§r"
	]
