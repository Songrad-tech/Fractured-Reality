	quest.72D5490BF61C8A34.title: "Andesite Alloy"
	quest.72EC9401EE3BA289.quest_desc: [
		"§7Many dimensions, structures, and hidden locations contain important resources, progression items, and fragments of lost knowledge.§r"
		" "
		"§6The world of Fractured Reality rewards curiosity.§r"
		" "
		"§fDo not remain underground forever.§r"
	]
	quest.72EC9401EE3BA289.title: "Exploration is Essential"
	quest.72F72CE103EE9BF9.quest_desc: ["&7The Chronon Battery stores the energy required by Tempad technology.&r"]
	quest.72F72CE103EE9BF9.quest_subtitle: "Temporal Technology"
	quest.72F72CE103EE9BF9.title: "Build a Chronon Battery"
	quest.7303890E9D4FFCCF.quest_desc: ["Dirt Seeds are humble, but they make terrain work and bulk crafting much less manual."]
	quest.7303890E9D4FFCCF.quest_subtitle: "Cultivated Dirt Essence"
	quest.7303890E9D4FFCCF.title: "Dirt Seeds"
	quest.73FEC50107D340CA.quest_desc: [
		"&7The Deep Drill extracts underground resources without another manual mining trip.&r"
		" "
		"&eIts sustained energy demand is high, so monitor generation before leaving it running.&r"
	]
	quest.73FEC50107D340CA.quest_subtitle: "Powered Industry"
	quest.73FEC50107D340CA.title: "Build a Deep Drill"
	quest.75AD0195B0CAF319.quest_desc: [
		"&7The Tesla Coil transfers electrical power without a direct cable between both ends.&r"
		" "
		"&eKeep both coils within range and make sure the sending coil is receiving power.&r"
	]
	quest.75AD0195B0CAF319.quest_subtitle: "New Technology"
	quest.75AD0195B0CAF319.title: "Build a Tesla Coil"
	quest.75CE2CADC4756616.quest_desc: [
		"Cloggrum is one of the first metals worth collecting in the Undergarden."
		" "
		"Mine raw Cloggrum and prepare it for refining."
	]
	quest.75CE2CADC4756616.quest_subtitle: "Undergarden Metal"
	quest.75CE2CADC4756616.title: "Mine Raw Cloggrum"
	quest.760E55F3762CEE14.title: "Armory Cabinet"
	quest.76B17947279E3743.quest_desc: ["&7Machine Core 3 advances Oritech equipment to technology tier 3.&r"]
	quest.76B17947279E3743.quest_subtitle: "Machine Core Tier 3"
	quest.76B17947279E3743.title: "Craft Machine Core 3"
	quest.76B954D68DD2F748.title: "Essence of Continuity"
	quest.77C38BE8ECF78C64.title: "Netherite Backpack"
	quest.77D9929025AD4DB1.title: "Wooden Glider"
	quest.790A807983D217D9.quest_desc: [
		"The Heart of the Deep is the key to reaching the Otherside."
		" "
		"Bring one back from the ancient depths and prepare for a dimension shaped by sculk."
	]
	quest.790A807983D217D9.quest_subtitle: "Doorway to the Otherside"
	quest.790A807983D217D9.title: "Obtain the Heart of the Deep"
	quest.792251FD6D6815C6.quest_desc: [
		"&7The 256K Cell Component expands the practical capacity of ME item storage.&r"
		" "
		"&eAutocraft the nested component chain instead of assembling every lower tier by hand.&r"
	]
	quest.792251FD6D6815C6.quest_subtitle: "256K Digital Capacity"
	quest.792251FD6D6815C6.title: "Craft Cell Component 256K"
	quest.7981CF7164F5B951.quest_desc: ["§fIt focuses your Ochrum exploration into the progression key for automated Gold production.§r"]
	quest.7981CF7164F5B951.quest_subtitle: "Custom Resource Core"
	quest.7981CF7164F5B951.title: "Craft an Ochrum Core"
	quest.7985206082FEEE58.quest_desc: ["Uranium Seeds turn high-energy materials into a planned farming project."]
	quest.7985206082FEEE58.quest_subtitle: "Cultivated Uranium Essence"
	quest.7985206082FEEE58.title: "Uranium Seeds"
	quest.79F4727AE5138702.quest_desc: ["Phantom Seeds are a peaceful answer to membrane farming and sleepless nights."]
	quest.79F4727AE5138702.quest_subtitle: "Cultivated Phantom Essence"
	quest.79F4727AE5138702.title: "Phantom Seeds"
	quest.7A4B44B343547F12.quest_desc: ["Capture light currents in Air Seeds and let the farm gather airy essence over time."]
	quest.7A4B44B343547F12.quest_subtitle: "Cultivated Air Essence"
	quest.7A4B44B343547F12.title: "Air Seeds"
	quest.7ABF9857AE02F946.quest_desc: [
		"&7Flux Dust is the first material used to build a wireless Flux Network.&r"
		" "
		"&ePerform the conversion in a controlled area and keep valuable loose items away from it.&r"
		" "
		"{image:minecraft:textures/gui/quests/flux_craft.png width:96 height:96 align:center}"
	]
	quest.7ABF9857AE02F946.quest_subtitle: "Wireless Energy"
	quest.7ABF9857AE02F946.title: "Create Flux Dust"
	quest.7AEF195E258F6020.title: "Backpack"
	quest.7B168B08E0B36F0C.quest_desc: [
		"&7A Molecular Assembler and Pattern Provider form the basic AE2 autocrafting pair.&r"
		" "
		"&fPlace them together, connect the provider to the ME network, and encode a simple crafting pattern.&r"
		" "
		"&eThe network also needs storage, power, an available channel, and enough crafting CPU space.&r"
	]
	quest.7B168B08E0B36F0C.quest_subtitle: "Digital Progression"
	quest.7B168B08E0B36F0C.title: "Begin ME Autocrafting"
	quest.7B993E1F7990D293.quest_desc: ["Experience Seeds convert growth into stored knowledge for enchanting and utility crafts."]
	quest.7B993E1F7990D293.quest_subtitle: "Cultivated Experience Essence"
	quest.7B993E1F7990D293.title: "Experience Seeds"
	quest.7B9A5E838B0A0A12.quest_desc: [
		"&7The Particle Accelerator is the major multiblock used to create exotic late-age materials.&r"
		" "
		"&fCraft its controller, motors, rings, and sensors, then assemble the complete structure with Oritech's guide.&r"
		" "
		"&eA reversed component or malformed ring prevents startup; inspect every layer.&r"
	]
	quest.7B9A5E838B0A0A12.quest_subtitle: "Powered Industry"
	quest.7B9A5E838B0A0A12.title: "Assemble the Particle Accelerator"
	quest.7BCF609A2E79A59A.quest_desc: [
		"&7The Infusion Altar combines essences and materials to create seeds, crystals, and other Mystical Agriculture components.&r"
		" "
		"&ePlace eight Infusion Pedestals around the altar and activate the recipe from its center.&r"
	]
	quest.7BCF609A2E79A59A.quest_subtitle: "The Heart of Seed Crafting"
	quest.7BCF609A2E79A59A.title: "Build an Infusion Altar"
	quest.7C20643129AD0134.title: "Chest"
	quest.7D04BE7ADA7A5793.title: "Gold Upgrade"
	quest.7D42EE8FAAC4C722.quest_desc: ["&7Tertium supports stronger seeds that replace increasingly dangerous or repetitive resource gathering.&r"]
	quest.7D42EE8FAAC4C722.quest_subtitle: "Tier Three Essence"
	quest.7D42EE8FAAC4C722.title: "Create Tertium Essence"
	quest.7E35B188166E3ED9.quest_desc: ["Wildfire Seeds bottle a hotter flame for recipes beyond ordinary blaze power."]
	quest.7E35B188166E3ED9.quest_subtitle: "Cultivated Wildfire Essence"
	quest.7E35B188166E3ED9.title: "Wildfire Seeds"
	quest.7E5877B8D86682A1.quest_desc: ["§fUse it to turn your Veridium exploration into automated Copper production.§r"]
	quest.7E5877B8D86682A1.quest_subtitle: "Custom Resource Core"
	quest.7E5877B8D86682A1.title: "Craft a Veridium Core"
	quest.7E5CC25A25302918.quest_desc: ["Regalium Seeds grow royal Undergarden metal essence for later progression gates."]
	quest.7E5CC25A25302918.quest_subtitle: "Cultivated Regalium Essence"
	quest.7E5CC25A25302918.title: "Regalium Seeds"
	quest.7EB58EB50EC527ED.quest_desc: ["Skeleton Seeds turn bones and arrows into dependable essence for combat and farming recipes."]
	quest.7EB58EB50EC527ED.quest_subtitle: "Cultivated Skeleton Essence"
	quest.7EB58EB50EC527ED.title: "Skeleton Seeds"
	quest.7EFC4A52220B1A80.quest_desc: [
		"The Infuser harnesses the unique energies found throughout the Undergarden."
		" "
		"Craft one to transform materials using the dimension's powerful crystals."
	]
	quest.7EFC4A52220B1A80.quest_subtitle: "Power of Infusion"
	quest.7EFC4A52220B1A80.title: "Craft an Infuser"
	quest.7F3839D206AED8BA.quest_desc: [
		"Forgotten metal still remembers how to become something powerful."
		" "
		"Obtain a Forgotten Ingot from the Undergarden's deeper challenges."
	]
	quest.7F3839D206AED8BA.quest_subtitle: "Recovered Metal"
	quest.7F3839D206AED8BA.title: "Obtain a Forgotten Ingot"
	quest.7FBE21826CC65EEB.quest_desc: [
		"§7The Mechanical Mixer combines ingredients with rotational force.§r"
		" "
		"§fPlace it above a Basin, feed items or fluids into the Basin, and power the mixer from above or the side.§r"
		" "
		"§6Some recipes need heat from a Blaze Burner underneath.§r"
	]
	quest.7FBE21826CC65EEB.quest_subtitle: "Basin Processing"
	quest.7FBE21826CC65EEB.title: "Craft a Mechanical Mixer"
	quest.7FD9E439525F1203.quest_desc: [
		"Craft an Ancient Compass with a normal compass surrounded by four Warden Carapaces."
		" "
		"Inside the Otherside, it points toward the nearest Ancient Temple you have not yet discovered."
	]
	quest.7FD9E439525F1203.quest_subtitle: "A Path Through the Gloom"
	quest.7FD9E439525F1203.title: "Craft an Ancient Compass"
	quest.8CB77B71C64448D4.quest_desc: [
		"The final desires demand specialized Bumblezone equipment and a great deal of patience."
		" "
		"Fire stingers, defeat the Wither with a Stinger Spear, slay the Ender Dragon in Bee Armor, and complete 128 Queen trades."
	]
	quest.8CB77B71C64448D4.quest_subtitle: "Proof of Devotion"
	quest.8CB77B71C64448D4.title: "The Queen's Great Feats"
	quest.8D36A2E96AAA4B69.quest_desc: [
		"Porous Sculk Gleam slowly grows Gleam Gel through several stages."
		" "
		"Use shears when the growth is ready. Sculk Snappers may also accept the gel as food."
	]
	quest.8D36A2E96AAA4B69.quest_subtitle: "Harvested Light"
	quest.8D36A2E96AAA4B69.title: "Harvest Gleam Gel"
	quest.93E20AA9DF4A4591.quest_desc: [
		"Resonarium equipment now requires a dedicated smithing template."
		" "
		"Search Ancient Cities, Trial Chambers, Stronghold corridors, or the apex of an Ancient Temple."
		" "
		"Once found, the template can be duplicated with Resonarium and diamonds."
	]
	quest.93E20AA9DF4A4591.quest_subtitle: "The Missing Pattern"
	quest.93E20AA9DF4A4591.title: "Find a Resonarium Upgrade"
	quest.95933F9B9FAB42A9.quest_desc: [
		"These desires focus on pollen, flowers, Honey Slimes, and injured bees."
		" "
		"Use the advancement descriptions for the required totals and equipment."
	]
	quest.95933F9B9FAB42A9.quest_subtitle: "Let the Hive Flourish"
	quest.95933F9B9FAB42A9.title: "The Queen's Garden"
	quest.A29BA901E42A4B32.quest_desc: [
		"Explore the Crystal Canyons and recover both normal and Glistering Honey Crystals."
		" "
		"Use their shards to craft a Honey Crystal Shield."
	]
	quest.A29BA901E42A4B32.quest_subtitle: "Fragile but Useful"
	quest.A29BA901E42A4B32.title: "Master Honey Crystals"
	quest.B21F9278165948F9.quest_desc: [
		"The Crystalline Flower consumes items and experience to grow."
		" "
		"Once developed, it can manipulate powerful enchantments through its own interface."
	]
	quest.B21F9278165948F9.quest_subtitle: "Feed the Flower"
	quest.B21F9278165948F9.title: "Grow a Crystalline Flower"
	quest.B23D617ADD704747.quest_desc: [
		"Combine four Royal Jelly Bottles with a Bucket to collect a full bucket."
		" "
		"Royal Jelly can empower bees for an extremely long time and can transform a Beehemoth into a Queen Beehemoth."
	]
	quest.B23D617ADD704747.quest_subtitle: "Concentrated Royalty"
	quest.B23D617ADD704747.title: "Fill a Royal Jelly Bucket"
	quest.BC9010C5006548C9.quest_desc: [
		"The Bee Queen is a peaceful trader, not a boss."
		" "
		"Hold or drop an item she accepts and complete one trade. This unlocks the hidden Queen's Desire advancement path."
	]
	quest.BC9010C5006548C9.quest_subtitle: "An Audience with Royalty"
	quest.BC9010C5006548C9.title: "Trade with the Bee Queen"
	quest.BCAD51DF3BC545D5.quest_desc: [
		"Find a Throne Pillar, the home of the Bee Queen."
		" "
		"Honey Compasses found in other Bumblezone structures can point toward her throne."
	]
	quest.BCAD51DF3BC545D5.quest_subtitle: "The Queen Awaits"
	quest.BCAD51DF3BC545D5.title: "Find the Throne Pillar"
	quest.C4CABF62252142CF.quest_desc: [
		"Combine the Resonarium Upgrade template, a diamond sword, and a Resonarium Plate in a Smithing Table."
		" "
		"The same method can upgrade the other supported diamond tools and armor."
	]
	quest.C4CABF62252142CF.quest_subtitle: "Diamond, Reforged"
	quest.C4CABF62252142CF.title: "Forge a Resonarium Weapon"
	quest.DE805BEE8B0D494A.quest_desc: [
		"The Bumblezone contains many distinct biomes and structures beyond the Queen's throne."
		" "
		"Discover every biome and enter every major structure."
	]
	quest.DE805BEE8B0D494A.quest_subtitle: "Leave No Cell Unexplored"
	quest.DE805BEE8B0D494A.title: "Explore the Entire Hive"
	quest.DF6DD5A8A1A74546.quest_desc: [
		"Angler Fish now swim through the pools of the Blooming Caverns."
		" "
		"Track one down to discover another form of life shaped by the Otherside."
	]
	quest.DF6DD5A8A1A74546.quest_subtitle: "Light Beneath the Water"
	quest.DF6DD5A8A1A74546.title: "Hunt an Angler Fish"
	quest.E375F06818474B98.quest_desc: [
		"Gloomsherds dropped by Overcast Pots can be assembled like pottery sherds."
		" "
		"Use four of them to craft a Gloomslate Pot capable of holding one stack of items."
	]
	quest.E375F06818474B98.quest_subtitle: "Pieces of Emotion"
	quest.E375F06818474B98.title: "Craft a Gloomslate Pot"
	quest.E5CB5F0CDB9444BB.quest_desc: [
		"Raise a Beehemoth's friendship to its maximum, then offer it Royal Jelly."
		" "
		"The transformation creates a Queen Beehemoth with permanent royal power."
	]
	quest.E5CB5F0CDB9444BB.quest_subtitle: "A Royal Transformation"
	quest.E5CB5F0CDB9444BB.title: "Create a Queen Beehemoth"
	quest.F1B74DE9725240D1.quest_desc: [
		"Sorrow, Fear, and Anger have taken physical form in the Overcast Columns."
		" "
		"Defeat all three Overcast Pot variants and gather the Gloomsherds left behind."
	]
	quest.F1B74DE9725240D1.quest_subtitle: "Shattered Emotions"
