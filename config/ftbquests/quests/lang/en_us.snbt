	quest.449B86794FC6FCE9.title: "Fish Seeds"
	quest.44BAE70AE87741B8.quest_desc: [
		"§6Brass Casings give advanced Create machines the frame they need.§r"
		" "
		"§fUse Brass on stripped logs, just like the earlier casing recipes.§r"
		" "
		"§7This is where your factory starts becoming less improvised.§r"
	]
	quest.44BAE70AE87741B8.quest_subtitle: "Advanced Framing"
	quest.44BAE70AE87741B8.title: "Craft a Brass Casing"
	quest.45739EFF174B971C.quest_desc: ["Slime Seeds make sticky crafting materials renewable without hunting swamps or caves."]
