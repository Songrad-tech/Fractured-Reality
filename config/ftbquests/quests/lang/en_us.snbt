	quest.0789D9872462D216.title: "Craft a Crimsite Core"
	quest.0860B05992C8E356.title: "Diamond Glider"
	quest.0A586098A85A17ED.title: "Essence of Calming"
	quest.0A5C056A2A1492A4.quest_desc: [
		"Utheric Shards carry a cold, alien energy found within the Undergarden."
		" "
		"Collect one to start working toward stronger materials."
	]
