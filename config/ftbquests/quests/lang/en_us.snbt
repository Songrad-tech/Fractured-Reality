	quest.2084432E2840239D.title: "Wood Seeds"
	quest.20CECAECE7438D7F.quest_desc: [
		"§7Create needs rotation before it can do anything clever.§r"
		" "
		"§fBuild a Water Wheel, Large Water Wheel, or Windmill Bearing to start moving shafts.§r"
		" "
		"§6Shafts, cogwheels, and gearboxes will carry that power into your machines.§r"
	]
	quest.20CECAECE7438D7F.quest_subtitle: "First Rotation"
	quest.20CECAECE7438D7F.title: "Create Rotational Power"
