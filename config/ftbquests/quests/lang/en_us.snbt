	quest.12D4330AEBD1E8E2.title: "Rabbit Seeds"
	quest.12F047277E8EE4FF.quest_desc: ["Dye Seeds are the tidy answer when recipes start asking for every color at once."]
	quest.12F047277E8EE4FF.quest_subtitle: "Cultivated Dye Essence"
	quest.12F047277E8EE4FF.title: "Dye Seeds"
	quest.134E8E70EF5D79E4.quest_desc: ["Flux Dust Seeds feed energy and redstone-adjacent crafting with a renewable crop."]
	quest.134E8E70EF5D79E4.quest_subtitle: "Cultivated Flux Dust Essence"
	quest.134E8E70EF5D79E4.title: "Flux Dust Seeds"
	quest.16A2C688BB865A46.quest_desc: ["Prismarine Seeds pull ocean monument materials into a safer renewable loop."]
