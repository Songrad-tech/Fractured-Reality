	quest.35690DA73DE6F776.title: "Craft a Resonarium Plate"
	quest.35C22982FC123B45.quest_desc: [
		"§7Some phenomena cannot be explained.§r"
		" "
		"§7You may encounter impossible structures, distorted landscapes, or fractures in the sky itself.§r"
		" "
		"§8If reality appears unstable...§r"
		" "
		"§4That is perfectly normal.§r"
	]
	quest.35C22982FC123B45.title: "Reality Feels... Wrong"
	quest.361CDDAF1904CA7D.title: "Time in a Bottle"
	quest.37A9D826BB297B64.quest_desc: ["Rogdorium Seeds secure a custom metal line before advanced recipes demand stacks of it."]
	quest.37A9D826BB297B64.quest_subtitle: "Cultivated Rogdorium Essence"
	quest.37A9D826BB297B64.title: "Rogdorium Seeds"
	quest.37AD46973FE4076D.quest_desc: [
		"§7Mechanical Arms route items between depots, belts, and inventories with careful targeting.§r"
		" "
		"§fRight-click valid pickup and deposit points while placing or configuring the arm.§r"
		" "
		"§6They shine once your factory needs decisions, not just motion.§r"
	]
	quest.37AD46973FE4076D.quest_subtitle: "Directed Logistics"
	quest.37AD46973FE4076D.title: "Craft a Mechanical Arm"
	quest.3A3FDB2C0738518C.quest_desc: [
		"§7Your machines are now strong enough to do more than process what you mine by hand.§r"
		" "
		"§fResource Generation lets you automate common materials so you can build, craft, and progress without returning to the caves every few minutes.§r"
		" "
		"§6Start by exploring for the stone resources used in the pack's custom cores.§r"
	]
	quest.3A3FDB2C0738518C.quest_subtitle: "Mine Less, Build More"
	quest.3A3FDB2C0738518C.title: "Begin Resource Generation"
