	quest.25B4817CC7F9D6A1.quest_desc: [
		"§6Challenge: Nickel should now come from your resource generator, not only from ore veins.§r"
		" "
		"§fProduce or gather 256 Nickel Ingots to prove the Viridite line is working.§r"
		" "
		"§7Let the system run, then collect from storage instead of babysitting every craft.§r"
