	quest.06D721CECB36C569.quest_subtitle: "Cultivated Zinc Essence"
	quest.06D721CECB36C569.title: "Zinc Seeds"
	quest.06EBFFCFCE57218A.quest_desc: ["Glowstone Seeds bring bright Nether dust home for lighting and magical recipes."]
	quest.06EBFFCFCE57218A.quest_subtitle: "Cultivated Glowstone Essence"
	quest.06EBFFCFCE57218A.title: "Glowstone Seeds"
