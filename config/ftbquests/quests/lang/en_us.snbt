	quest.0A5C056A2A1492A4.title: "Find Utheric Shards"
	quest.0D766B72F550F11A.quest_desc: ["Utherium Seeds cultivate alien Undergarden energy for stronger custom materials."]
	quest.0D766B72F550F11A.quest_subtitle: "Cultivated Utherium Essence"
	quest.0D766B72F550F11A.title: "Utherium Seeds"
	quest.0DC9B4CBE1642B75.quest_desc: [
		"§7The Andesite Core is the first real checkpoint of the Mechanical Age.§r"
		" "
		"§fOnce you can craft it, early automation opens up quickly: pressing, mixing, cutting, drilling, and deploying all begin here.§r"
	]
	quest.0DC9B4CBE1642B75.quest_subtitle: "First Mechanical Core"
	quest.0DC9B4CBE1642B75.title: "Craft an Andesite Core"
	quest.0E18DE2A29892903.quest_desc: [
		"§6Challenge: prove that Iron is no longer only a mining trip.§r"
		" "
		"§fProduce or gather 256 Iron Ingots through your automated resource setup.§r"
		" "
		"§7A buffer drawer, chest, or storage system makes this much easier to validate cleanly.§r"
	]
	quest.0E18DE2A29892903.quest_subtitle: "Automation Check"
	quest.0E18DE2A29892903.title: "Generate Iron"
	quest.0F5AC97C67C06135.title: "Diamond Barrel"
	quest.0FCAE2FFD1263B87.quest_desc: [
		"§7Zinc carries the first traces of mechanical potential.§r"
		" "
		"§fFind and smelt zinc to prepare your first custom alloy recipe.§r"
		" "
		"§6JEI will help you locate the correct recipe path if needed.§r"
	]
	quest.0FCAE2FFD1263B87.quest_subtitle: "First Metal"
	quest.0FCAE2FFD1263B87.title: "Find Zinc"
	quest.1080F263719CA71F.quest_desc: ["Nether Quartz Seeds support comparators, machines, and refined Nether crafting from home."]
	quest.1080F263719CA71F.quest_subtitle: "Cultivated Nether Quartz Essence"
	quest.1080F263719CA71F.title: "Nether Quartz Seeds"
	quest.1101CDC12DFDBAB4.quest_desc: [
		"Warden Carapaces can be recovered from Wardens and, more rarely, from Ancient City chests."
		" "
		"Collect four of them. They are needed to craft the compass that reveals an undiscovered Ancient Temple."
	]
	quest.1101CDC12DFDBAB4.quest_subtitle: "Fragments of the Warden"
	quest.1101CDC12DFDBAB4.title: "Collect Warden Carapaces"
	quest.1152D0121612345C.quest_desc: [
		"§7The Mechanical Saw cuts logs, strips blocks, and becomes the heart of simple wood automation.§r"
		" "
		"§6Feed it rotation and use belts, depots, or chutes to move items through it.§r"
	]
	quest.1152D0121612345C.quest_subtitle: "Automated Cutting"
	quest.1152D0121612345C.title: "Craft a Mechanical Saw"
	quest.116B91C74588FDB0.quest_desc: [
		"§7Raw wood is useful, but planks are where crafting truly begins.§r"
		" "
		"§fConvert your logs into planks and prepare your first workspace.§r"
	]
	quest.116B91C74588FDB0.quest_subtitle: "First Materials"
	quest.116B91C74588FDB0.title: "Craft Planks"
	quest.11AF2176193077FD.quest_desc: [
		"§7Asurine is one of Create's decorative stone families, usually found through exploration and mining.§r"
		" "
		"§fGather 16 Asurine to prepare the custom core recipe tied to Zinc generation.§r"
		" "
		"&eThis part is intentionally exploration-first: find the resource, then automate the metal.&r"
	]
	quest.11AF2176193077FD.quest_subtitle: "Exploration Material"
	quest.11AF2176193077FD.title: "Gather Asurine"
	quest.125AEB10070AAA43.title: "Essence of Life"
	quest.128BDDD7D750138C.quest_desc: [
		"§7Hand crafting may help you survive the early days.§r"
		" "
		"§fBut true progression begins with machines, logistics, and automated production.§r"
		" "
		"§6The more you automate, the further you will go.§r"
	]
	quest.128BDDD7D750138C.title: "Automation is the Key"
	quest.1290994D6E074626.quest_desc: [
		"The Essence of the Bees is a permanent infusion, not a crafting ingredient."
		" "
		"Consume it to gain the Queen's blessing and unlock safe access to the Sempiternal Sanctums."
	]
	quest.1290994D6E074626.quest_subtitle: "The Hive Accepts You"
	quest.1290994D6E074626.title: "Consume the Essence"
