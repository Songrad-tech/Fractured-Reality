	quest.72A610C3E3B1C7AE.title: "Nature Seeds"
	quest.72AD0CAC23AC335D.quest_desc: ["&7The 4K Cell Component expands the practical capacity of ME item storage.&r"]
	quest.72AD0CAC23AC335D.quest_subtitle: "4K Digital Capacity"
	quest.72AD0CAC23AC335D.title: "Craft Cell Component 4K"
